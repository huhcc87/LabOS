# ════════════════════════════════════════════════════════════════════════
# LabOS v3 — Backend environment variables (FastAPI)
# Copy this file to `.env` for local development, or set as real env vars
# in your deployment environment (Docker / Render / Fly.io / Railway).
# ════════════════════════════════════════════════════════════════════════

# ─── Core ────────────────────────────────────────────────────────────────
# REQUIRED in production. Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=

# Set to "production" in deployed environments. Anything else means dev.
ENVIRONMENT=development

APP_NAME=LabOS v3
ACCESS_TOKEN_EXPIRE_MINUTES=120
SCHEDULER_INTERVAL_SECONDS=60

# ─── Database ────────────────────────────────────────────────────────────
# Default: local SQLite (works for dev / single-user).
DATABASE_URL=sqlite:///./lab.db

# Production: Neon Postgres (free tier supports up to 0.5 GB + autosuspend).
# Get your URL at https://console.neon.tech → your-project → Connection Details
# Format:
#   postgresql+psycopg://USER:PASSWORD@ep-something-12345.us-east-2.aws.neon.tech/labos?sslmode=require
# DATABASE_URL=postgresql+psycopg://neondb_owner:XXX@ep-XXX.neon.tech/labos?sslmode=require

# ─── CORS — domains allowed to call this API ────────────────────────────
# Comma-separated. Add Vercel deployment URL + any custom domains.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ─── File uploads ───────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# ─── Email / SMTP (optional) ────────────────────────────────────────────
# Leave blank to disable email delivery.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@yourdomain.com
SMTP_TLS=true

# ─── Stripe (in-app reagent purchasing) ─────────────────────────────────
# Get keys at https://dashboard.stripe.com/apikeys
# - Test mode keys start with sk_test_ / pk_test_
# - Live mode keys start with sk_live_ / pk_live_
# Use test keys until you've fully tested the checkout flow.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── Twilio SMS (optional, for procurement-critical alerts) ─────────────
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_FROM=

# ─── AI (optional) ──────────────────────────────────────────────────────
# Leave blank to use template-based generation for protocols / grants.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ─── IoT / MQTT (optional) ──────────────────────────────────────────────
# Leave blank to disable MQTT relay. Used by IoT sensor integration.
MQTT_BROKER_HOST=
MQTT_BROKER_PORT=1883
MQTT_TOPIC=lab/sensors/#

# ─── Cloudflare R2 (optional, for file uploads at scale) ────────────────
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=labos-uploads
# R2_PUBLIC_URL=https://pub-XXX.r2.dev

# ─── Crowdsourced enrichment opt-in (for the extension) ─────────────────
LABOS_CROWDSOURCE_ENRICH=false
