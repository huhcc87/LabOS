# ════════════════════════════════════════════════════════════════════════
# LabOS v3 — Production Environment Variables
# Copy these into Railway → Variables (never commit real values to git)
# ════════════════════════════════════════════════════════════════════════

# ── Database (Neon PostgreSQL) ──────────────────────────────────────────
# Paste the "Connection string" from Neon dashboard (Pooled connection recommended)
DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/labos?sslmode=require

# ── Security ────────────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=CHANGE_ME_48_CHAR_RANDOM_STRING
ENVIRONMENT=production

# ── CORS — add your Vercel URL once deployed ────────────────────────────
# Example: https://labos.vercel.app,https://your-custom-domain.com
CORS_ORIGINS=https://YOUR_APP.vercel.app

# ── AI providers (add whichever keys you have) ──────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
DEEPSEEK_API_KEY=sk-c2b1420edb304c53aedfea0e25be3986
OPENAI_API_KEY=sk-proj-...

# ── File uploads (Railway ephemeral disk → use Cloudflare R2 for production) ──
# Leave blank to use local /data/uploads (Railway persistent volume)
# Or set to use R2:
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_ENDPOINT_URL=https://ACCOUNT.r2.cloudflarestorage.com
# AWS_S3_BUCKET=labos-uploads
UPLOAD_DIR=/data/uploads

# ── Email (Resend recommended for production) ───────────────────────────
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=465
# SMTP_USER=resend
# SMTP_PASSWORD=re_...
# SMTP_FROM=noreply@yourdomain.com
# SMTP_TLS=true

# ── Stripe (optional — for reagent cart checkout) ───────────────────────
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
