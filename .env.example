# LabOS — environment variables
# Copy to .env and fill in values before running in production.
# Development defaults work out-of-the-box without this file.

# ── Security ──────────────────────────────────────────────────────────────
# REQUIRED for production — generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-min-32-chars-use-secrets-token-urlsafe

# ── Database ──────────────────────────────────────────────────────────────
# SQLite (default, development)
DATABASE_URL=sqlite:///./lab.db
# PostgreSQL (production)
# DATABASE_URL=postgresql+psycopg://user:password@host:5432/labos

# ── CORS ──────────────────────────────────────────────────────────────────
# Comma-separated or JSON array of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,https://your-domain.com

# ── Environment ───────────────────────────────────────────────────────────
ENVIRONMENT=production

# ── SMTP / Email ──────────────────────────────────────────────────────────
# Leave blank to disable email delivery (notifications will still log).
# Works with any SMTP provider: Gmail, SendGrid, Mailgun, AWS SES, etc.
#
# Gmail example:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_USER=you@gmail.com
#   SMTP_PASSWORD=your-app-password   (not your login password — use App Passwords)
#
# SendGrid example:
#   SMTP_HOST=smtp.sendgrid.net
#   SMTP_USER=apikey
#   SMTP_PASSWORD=SG.xxxx
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=labos@your-domain.com
SMTP_TLS=true

# ── OpenAI (AI features) ───────────────────────────────────────────────────
# Leave blank to use template-based fallbacks (protocol gen, grant writing).
OPENAI_API_KEY=

# ── IoT / MQTT ────────────────────────────────────────────────────────────
# Leave blank to disable MQTT sensor ingestion.
MQTT_BROKER_HOST=
MQTT_BROKER_PORT=1883
MQTT_TOPIC=lab/sensors/#

# ── Storage ───────────────────────────────────────────────────────────────
# Local disk (default). For production use S3/R2:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=labos-uploads
# AWS_S3_REGION=us-east-1
