# ════════════════════════════════════════════════════════════════════════
# LabOS v3 — Frontend environment variables (Vite)
# Copy to `.env` for local dev, or set as Vercel/Netlify build-time vars.
# ════════════════════════════════════════════════════════════════════════

# Base URL for backend API.
# - Local dev: leave as "/api" — relies on Vite dev proxy in vite.config.ts
# - Vercel/production: full origin of your backend
#   e.g. VITE_API_BASE_URL=https://your-labos-api.fly.dev/api
VITE_API_BASE_URL=/api

# Branding
VITE_APP_NAME=LabOS

# Stripe publishable key (safe to expose — public by design).
# Required only if you want in-app card entry on the Payment Methods page.
# Get at https://dashboard.stripe.com/apikeys
# Use pk_test_… until you're done testing, then swap to pk_live_…
VITE_STRIPE_PUBLISHABLE_KEY=
