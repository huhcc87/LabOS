# ════════════════════════════════════════════════════════════════════════
# LabOS v3 — Frontend environment variables (Vite)
# Copy to `.env.local` for local dev, or set as Vercel/Netlify build-time vars.
# ════════════════════════════════════════════════════════════════════════

# ── Convex (required) ─────────────────────────────────────────────────
# Your Convex deployment URL. Get it from https://dashboard.convex.dev
VITE_CONVEX_URL=
VITE_CONVEX_SITE_URL=

# ── Branding ──────────────────────────────────────────────────────────
VITE_APP_NAME=LabOS
VITE_APP_VERSION=1.0.0

# ── Error Tracking (Sentry — optional) ───────────────────────────────
# Get DSN from https://sentry.io → Project Settings → Client Keys
VITE_SENTRY_DSN=

# ── Analytics (PostHog — optional) ────────────────────────────────────
# Get key from https://posthog.com → Project Settings → Project API Key
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://app.posthog.com

# ── Performance Monitoring (optional) ─────────────────────────────────
# Endpoint for Web Vitals data (e.g., your own analytics API)
VITE_ANALYTICS_URL=

# ── Stripe (optional) ────────────────────────────────────────────────
# Publishable key for Payment Methods page
# Get at https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=
