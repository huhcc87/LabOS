# ════════════════════════════════════════════════════════════════════════
# LabOS v3 — Frontend environment variables (Vite)
# Copy to `.env.local` for local dev, or set as Vercel/Netlify build-time vars.
# ════════════════════════════════════════════════════════════════════════

# ── Convex (required) ─────────────────────────────────────────────────
# Your Convex deployment URL. Get it from https://dashboard.convex.dev
VITE_CONVEX_URL=
VITE_CONVEX_SITE_URL=

# ── Branding ──────────────────────────────────────────────────────────
VITE_APP_NAME=LabOS
VITE_APP_VERSION=1.0.0

# ── Analytics (Vercel Analytics — auto-enabled on Vercel Pro) ─────────
# PostHog is optional if you want additional analytics
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://app.posthog.com

# ── Stripe (optional) ────────────────────────────────────────────────
# Publishable key for Payment Methods page
# Get at https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=
