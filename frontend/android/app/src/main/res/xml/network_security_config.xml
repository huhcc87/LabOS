<?xml version="1.0" encoding="utf-8"?>
<!--
  Allows LabOS to reach the local lab server over plain HTTP
  (e.g. http://192.168.1.10:8000) while keeping HTTPS required
  for everything else on the public internet.
-->
<network-security-config>
    <!-- Trust system CAs for all public traffic -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- Allow cleartext HTTP only for private / LAN ranges -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">127.0.0.1</domain>
        <domain includeSubdomains="true">10.0.0.0</domain>
        <domain includeSubdomains="true">192.168.0.0</domain>
        <domain includeSubdomains="true">172.16.0.0</domain>
    </domain-config>
</network-security-config>
